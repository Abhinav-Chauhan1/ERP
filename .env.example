# Cashfree Payment Gateway — PLATFORM LEVEL (SaaS subscription billing only)
# Schools configure their own Cashfree keys via Admin → Settings → Payment Configuration
# Note: Cashfree uses CASHFREE_SECRET_KEY for both API calls AND webhook signature verification
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
NEXT_PUBLIC_CASHFREE_ENV="sandbox"   # or "production"

# Application URL (used in payment returnUrl / notifyUrl)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# CSRF
CSRF_SECRET=""

# Email (MSG91 or SMTP)
